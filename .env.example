VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_EITAA_MONITOR_API_URL=http://127.0.0.1:4179

VITE_SHOW_EITAA_AUTO_CALL=false

# Optional Eitaa/Puppeteer settings used by server/eitaa-monitor.mjs
EITAA_MONITOR_PORT=4179
EITAA_TARGET_URL=https://web.eitaa.com/#@Moarefe_Moshavere
EITAA_USER_DATA_DIR=/home/you/.config/google-chrome
EITAA_PROFILE_DIRECTORY=Default
EITAA_COPY_PROFILE_ON_LOCK=1
EITAA_MESSAGE_SELECTOR=
EITAA_SCROLL_CONTAINER_SELECTOR=
EITAA_AUTHOR_SELECTOR=
EITAA_TIME_SELECTOR=
EITAA_MESSAGE_TEXT_SELECTOR=
